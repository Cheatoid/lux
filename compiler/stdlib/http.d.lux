-- HTTP client exposed by the Lux runtime. Accessible as the global `http`.
--
-- All requests block the calling coroutine until they finish. Option tables
-- may carry: headers ({ [string]: string }), query ({ [string]: any }),
-- body (string), json (any, encoded as JSON), timeout (number, seconds).

declare interface HttpResponse
    status: number
    ok: boolean
    body: string
    headers: { [string]: string }
end

declare interface HttpOptions
    headers: { [string]: string }
    query: { [string]: any }
    body: string
    json: any
    timeout: number
end

declare http: {
    get: (string, HttpOptions?) -> HttpResponse,
    post: (string, HttpOptions?) -> HttpResponse,
    put: (string, HttpOptions?) -> HttpResponse,
    patch: (string, HttpOptions?) -> HttpResponse,
    delete: (string, HttpOptions?) -> HttpResponse,
    request: (string, string, HttpOptions?) -> HttpResponse,
    postjson: (string, any) -> HttpResponse,
    download: (string, string) -> number,
    getString: (string) -> string,
}
