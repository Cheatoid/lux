-- High-level project scaffolding helpers. Accessible as the global `project`.
-- Designed for use inside setup.lux scripts run by `lux create`.

declare project: {
    writeGitignore: (string, string[]?) -> nil,
    writeConfig: (string, { [string]: any }) -> nil,
    writeFile: (string, string) -> nil,
    runShell: (string, string?) -> number,
    gitInit: (string, boolean?, string?) -> boolean,
    installDeps: (string?, boolean?) -> boolean,
}
