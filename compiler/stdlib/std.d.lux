-- Standard Lua library type declarations.
--
-- Covers Lua 5.1 .. 5.4 plus the most common LuaJIT additions (bit, jit, ffi).
-- Everything here lives at the package root and can be disabled per package or
-- per function via the [stdlib] section in lux.toml:
--
--     [stdlib]
--     disabled = ["debug", "loadstring", "string.dump"]
--
-- Top-level globals (e.g. "print") and packages (e.g. "math") use bare names.
-- Members of a package are referenced with a dotted path ("string.format").
--
-- A few Lua identifiers (string.match, ffi.new, ffi.typeof, ...) collide with
-- reserved Lux keywords and are therefore not declared here; reach them via
-- bracket access (e.g. string["match"](...)) at the call site.

-- --- Built-in Globals ------------------------------------------------------

declare _G: { [string]: any }
declare _ENV: { [string]: any }
declare _VERSION: string

-- --- Built-in Functions ----------------------------------------------------

declare function print(...: any): nil
declare function type(v: any): string
declare function tostring(v: any): string
declare function tonumber(v: any, base: number?): number?
declare function ipairs(t: any): any
declare function pairs(t: any): any
declare function next(t: any, key: any?): any
declare function select(n: any, ...: any): any
declare function error(message: any, level: number?): nil
declare function assert(v: any, message: any?): any
declare function pcall(f: any, ...: any): any
declare function xpcall(f: any, handler: any, ...: any): any
declare function unpack(list: any, i: number?, j: number?): any
declare function rawget(t: any, key: any): any
declare function rawset(t: any, key: any, v: any): any
declare function rawequal(a: any, b: any): boolean
declare function rawlen(t: any): number
declare function setmetatable(t: any, mt: any?): any
declare function getmetatable(t: any): any
declare function require(modname: string): any
declare function dofile(filename: string?): any
declare function loadfile(filename: string?, mode: string?, env: any?): any
declare function load(chunk: any, chunkname: string?, mode: string?, env: any?): any
declare function loadstring(s: string, chunkname: string?): any
declare function collectgarbage(opt: string?, arg: any?): any

-- --- string ----------------------------------------------------------------

declare interface StringLib
    function byte(s: string, i: number?, j: number?): number
    function char(...: number): string
    function dump(f: any, strip: boolean?): string
    function find(s: string, pattern: string, init: number?, plain: boolean?): (number?, number?)
    function format(fmt: string, ...: any): string
    function gmatch(s: string, pattern: string): any
    function gsub(s: string, pattern: string, repl: any, n: number?): (string, number)
    function len(s: string): number
    function lower(s: string): string
    function rep(s: string, n: number, sep: string?): string
    function reverse(s: string): string
    function sub(s: string, i: number, j: number?): string
    function upper(s: string): string
    function pack(fmt: string, ...: any): string
    function packsize(fmt: string): number
    function unpack(fmt: string, s: string, pos: number?): any
end

declare string: StringLib

-- --- table -----------------------------------------------------------------

declare interface TableLib
    function concat(list: any, sep: string?, i: number?, j: number?): string
    function insert(list: any, posOrValue: any, value: any?): nil
    function remove(list: any, pos: number?): any
    function sort(list: any, comp: any?): nil
    function unpack(list: any, i: number?, j: number?): any
    function pack(...: any): any
    function move(a1: any, f: number, e: number, t: number, a2: any?): any
    function maxn(list: any): number
    function getn(list: any): number
end

declare table: TableLib

-- --- math ------------------------------------------------------------------

declare interface MathLib
    pi: number
    huge: number
    mininteger: number
    maxinteger: number

    function abs(x: number): number
    function acos(x: number): number
    function asin(x: number): number
    function atan(y: number, x: number?): number
    function atan2(y: number, x: number): number
    function ceil(x: number): number
    function cos(x: number): number
    function cosh(x: number): number
    function deg(x: number): number
    function exp(x: number): number
    function floor(x: number): number
    function fmod(x: number, y: number): number
    function frexp(x: number): (number, number)
    function ldexp(m: number, e: number): number
    function log(x: number, base: number?): number
    function log10(x: number): number
    function max(...: number): number
    function min(...: number): number
    function modf(x: number): (number, number)
    function pow(x: number, y: number): number
    function rad(x: number): number
    function random(m: number?, n: number?): number
    function randomseed(seed: number?, ...: number): nil
    function sin(x: number): number
    function sinh(x: number): number
    function sqrt(x: number): number
    function tan(x: number): number
    function tanh(x: number): number
    function tointeger(x: any): number?
    function type(x: any): string?
    function ult(m: number, n: number): boolean
end

declare math: MathLib

-- --- io --------------------------------------------------------------------

declare interface IoFile
    function close(self: any): boolean
    function flush(self: any): any
    function lines(self: any, ...: any): any
    function read(self: any, ...: any): any
    function seek(self: any, whence: string?, offset: number?): number?
    function setvbuf(self: any, mode: string, size: number?): any
    function write(self: any, ...: any): any
end

declare interface IoLib
    stdin: IoFile
    stdout: IoFile
    stderr: IoFile

    function open(filename: string, mode: string?): IoFile?
    function close(file: any?): any
    function flush(): any
    function input(file: any?): IoFile
    function output(file: any?): IoFile
    function lines(filename: string?, ...: any): any
    function read(...: any): any
    function write(...: any): any
    function popen(prog: string, mode: string?): IoFile?
    function tmpfile(): IoFile
    function type(obj: any): string?
end

declare io: IoLib

-- --- os --------------------------------------------------------------------

declare interface OsLib
    function clock(): number
    function date(format: string?, time: number?): any
    function difftime(t2: number, t1: number): number
    function execute(command: string?): any
    function exit(code: any?, close: boolean?): nil
    function getenv(varname: string): string?
    function remove(filename: string): boolean
    function rename(oldname: string, newname: string): boolean
    function setlocale(locale: string?, category: string?): string?
    function time(t: any?): number
    function tmpname(): string
end

declare os: OsLib

-- --- coroutine -------------------------------------------------------------

declare interface CoroutineLib
    function create(f: any): any
    function resume(co: any, ...: any): any
    function yield(...: any): any
    function status(co: any): string
    function wrap(f: any): any
    function isyieldable(co: any?): boolean
    function running(): (any, boolean)
    function close(co: any): (boolean, any)
end

declare coroutine: CoroutineLib

-- --- debug -----------------------------------------------------------------

declare interface DebugLib
    function debug(): nil
    function gethook(co: any?): any
    function getinfo(thread: any, f: any?, what: string?): any
    function getlocal(thread: any, level: any, idx: number?): any
    function getmetatable(value: any): any
    function getregistry(): any
    function getupvalue(f: any, up: number): any
    function getuservalue(u: any, n: number?): any
    function sethook(thread: any, hook: any?, mask: string?, count: number?): nil
    function setlocal(thread: any, level: any, idx: number, value: any?): string?
    function setmetatable(value: any, table: any?): any
    function setupvalue(f: any, up: number, value: any): string?
    function setuservalue(udata: any, value: any, n: number?): any
    function traceback(thread: any?, message: any?, level: number?): string
    function upvalueid(f: any, n: number): any
    function upvaluejoin(f1: any, n1: number, f2: any, n2: number): nil
end

declare debug: DebugLib

-- --- package ---------------------------------------------------------------

declare interface PackageLib
    config: string
    cpath: string
    path: string
    loaded: { [string]: any }
    preload: { [string]: any }
    searchers: any
    loaders: any

    function loadlib(libname: string, funcname: string): any
    function searchpath(name: string, path: string, sep: string?, rep: string?): string?
    function seeall(mod: any): nil
end

declare package: PackageLib

-- --- bit32 / bit (LuaJIT, Lua 5.2) -----------------------------------------

declare interface BitLib
    function arshift(x: number, n: number): number
    function band(...: number): number
    function bnot(x: number): number
    function bor(...: number): number
    function bxor(...: number): number
    function btest(...: number): boolean
    function extract(n: number, field: number, width: number?): number
    function replace(n: number, v: number, field: number, width: number?): number
    function lrotate(x: number, n: number): number
    function rrotate(x: number, n: number): number
    function lshift(x: number, n: number): number
    function rshift(x: number, n: number): number
    function tobit(x: number): number
    function tohex(x: number, n: number?): string
end

declare bit: BitLib
declare bit32: BitLib

-- --- jit / ffi (LuaJIT) ----------------------------------------------------

declare interface JitLib
    version: string
    version_num: number
    arch: string
    os: string

    function on(...: any): nil
    function off(...: any): nil
    function flush(...: any): nil
    function status(): any
    function attach(callback: any, event: string?): nil
end

declare jit: JitLib

-- Note: ffi.new and ffi.typeof aren't declared because `new` and `typeof` are
-- reserved Lux keywords; access them via ffi["new"] / ffi["typeof"] at the
-- call site for now.
declare interface FfiLib
    C: any
    arch: string
    os: string

    function cdef(def: string): nil
    function load(name: string, global: boolean?): any
    function cast(ct: any, init: any): any
    function metatype(ct: any, metatable: any): any
    function gc(cdata: any, finalizer: any): any
    function sizeof(ct: any, nelem: number?): number
    function alignof(ct: any): number
    function offsetof(ct: any, field: string): number
    function istype(ct: any, obj: any): boolean
    function errno(newerr: number?): number
    function string(ptr: any, len: number?): string
    function copy(dst: any, src: any, len: number?): nil
    function fill(dst: any, len: number, c: any?): nil
    function abi(param: string): boolean
end

declare ffi: FfiLib
