{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Lux",
  "scopeName": "source.lux",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#annotations" },
    { "include": "#numbers" },
    { "include": "#constants" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#declarations" },
    { "include": "#function-calls" },
    { "include": "#operators" },
    { "include": "#variables" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.documentation.lux",
          "begin": "---\\[\\[",
          "end": "\\]\\]",
          "patterns": [
            { "include": "#doc-tags" }
          ]
        },
        {
          "name": "comment.block.lux",
          "begin": "--\\[(=*)\\[",
          "end": "\\]\\1\\]"
        },
        {
          "name": "comment.line.documentation.lux",
          "begin": "---",
          "end": "$",
          "patterns": [
            { "include": "#doc-tags" }
          ]
        },
        {
          "name": "comment.line.double-dash.lux",
          "match": "--.*$"
        }
      ]
    },
    "doc-tags": {
      "patterns": [
        {
          "name": "storage.type.class.luadoc.lux",
          "match": "@(param|return|type|class|field|see|throws|since|deprecated|module|generic|alias)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.lux",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "include": "#string-escapes" }
          ]
        },
        {
          "name": "string.quoted.single.lux",
          "begin": "'",
          "end": "'",
          "patterns": [
            { "include": "#string-escapes" }
          ]
        },
        {
          "name": "string.interpolated.lux",
          "begin": "`",
          "end": "`",
          "patterns": [
            { "include": "#string-escapes" },
            {
              "name": "meta.interpolation.lux",
              "begin": "\\{",
              "end": "\\}",
              "beginCaptures": {
                "0": { "name": "punctuation.section.embedded.begin.lux" }
              },
              "endCaptures": {
                "0": { "name": "punctuation.section.embedded.end.lux" }
              },
              "patterns": [
                { "include": "$self" }
              ]
            }
          ]
        },
        {
          "name": "string.quoted.other.long.lux",
          "begin": "\\[(=*)\\[",
          "end": "\\]\\1\\]"
        }
      ]
    },
    "string-escapes": {
      "patterns": [
        {
          "name": "constant.character.escape.lux",
          "match": "\\\\(?:[abfnrtv\\\\\"'`\\n]|x[0-9A-Fa-f]{1,2}|z|\\d{1,3}|u\\{[0-9A-Fa-f]+\\})"
        }
      ]
    },
    "annotations": {
      "patterns": [
        {
          "name": "meta.annotation.lux",
          "begin": "(@)([A-Za-z_]\\w*)",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.annotation.lux" },
            "2": { "name": "entity.name.function.decorator.lux" }
          },
          "end": "(?<=\\))|(?=[\\s\\S])",
          "patterns": [
            {
              "begin": "\\(",
              "end": "\\)",
              "beginCaptures": {
                "0": { "name": "punctuation.section.parens.begin.lux" }
              },
              "endCaptures": {
                "0": { "name": "punctuation.section.parens.end.lux" }
              },
              "patterns": [
                { "include": "$self" }
              ]
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.lux",
          "match": "\\b0[xX][0-9a-fA-F](?:[0-9a-fA-F_]*[0-9a-fA-F])?(?:\\.[0-9a-fA-F]+)?(?:[pP][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.binary.lux",
          "match": "\\b0[bB][01](?:[01_]*[01])?\\b"
        },
        {
          "name": "constant.numeric.float.lux",
          "match": "\\b[0-9](?:[0-9_]*[0-9])?\\.[0-9](?:[0-9_]*[0-9])?(?:[eE][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.integer.lux",
          "match": "\\b[0-9](?:[0-9_]*[0-9])?(?:[eE][+-]?[0-9]+)?\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.lux",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.nil.lux",
          "match": "\\bnil\\b"
        },
        {
          "name": "variable.language.self.lux",
          "match": "\\bself\\b"
        },
        {
          "name": "variable.language.super.lux",
          "match": "\\bsuper\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.flow.lux",
          "match": "\\b(if|then|else|elseif|end|for|in|while|do|repeat|until|break|return|goto|continue|defer|guard)\\b"
        },
        {
          "name": "keyword.control.match.lux",
          "match": "\\b(match|case|when)\\b"
        },
        {
          "name": "keyword.control.import.lux",
          "match": "\\b(import|export|from|as|module)\\b"
        },
        {
          "name": "keyword.control.async.lux",
          "match": "\\b(async|await)\\b"
        },
        {
          "name": "storage.modifier.lux",
          "match": "\\b(local|mut|const|static|protected|abstract|override|declare|meta)\\b"
        },
        {
          "name": "storage.type.lux",
          "match": "\\b(function|class|interface|enum|extends|implements|operator|constructor|new)\\b"
        },
        {
          "name": "keyword.operator.logical.word.lux",
          "match": "\\b(and|or|not)\\b"
        },
        {
          "name": "keyword.operator.type.lux",
          "match": "\\b(is|as|typeof|instanceof)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.lux",
          "match": "\\b(string|number|boolean|any|void)\\b"
        },
        {
          "match": "(:)\\s*([A-Za-z_]\\w*)",
          "captures": {
            "1": { "name": "punctuation.separator.type.lux" },
            "2": { "name": "entity.name.type.lux" }
          }
        },
        {
          "match": "\\b(extends|implements|is|as)\\s+([A-Z][\\w]*)",
          "captures": {
            "1": { "name": "keyword.operator.type.lux" },
            "2": { "name": "entity.name.type.lux" }
          }
        },
        {
          "match": "(<)([A-Z][\\w]*(?:\\s*,\\s*[A-Z][\\w]*)*)(>)",
          "captures": {
            "1": { "name": "punctuation.definition.typeparameters.begin.lux" },
            "2": { "name": "entity.name.type.parameter.lux" },
            "3": { "name": "punctuation.definition.typeparameters.end.lux" }
          }
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "match": "\\b(function)\\s+([A-Za-z_][\\w]*(?:[.:][A-Za-z_][\\w]*)*)",
          "captures": {
            "1": { "name": "storage.type.function.lux" },
            "2": { "name": "entity.name.function.lux" }
          }
        },
        {
          "match": "\\b(class|interface|enum)\\s+([A-Za-z_]\\w*)",
          "captures": {
            "1": { "name": "storage.type.lux" },
            "2": { "name": "entity.name.type.class.lux" }
          }
        },
        {
          "match": "\\b(import)\\s+(\\*)\\s+(as)\\s+([A-Za-z_]\\w*)",
          "captures": {
            "1": { "name": "keyword.control.import.lux" },
            "2": { "name": "keyword.operator.lux" },
            "3": { "name": "keyword.control.import.lux" },
            "4": { "name": "variable.other.namespace.lux" }
          }
        }
      ]
    },
    "function-calls": {
      "patterns": [
        {
          "match": "\\b([A-Za-z_]\\w*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.call.lux" }
          }
        },
        {
          "match": "(?<=[.:])([A-Za-z_]\\w*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.method.lux" }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.lux",
          "match": "(?:\\+\\+|~~|\\+=|-=|\\*=|/=|%=|\\^=|\\.\\.=|=)"
        },
        {
          "name": "keyword.operator.comparison.lux",
          "match": "==|~=|!=|<=|>=|<(?![A-Za-z_])|>(?![A-Za-z_])"
        },
        {
          "name": "keyword.operator.logical.lux",
          "match": "&&|\\|\\||!(?!=)"
        },
        {
          "name": "keyword.operator.range.lux",
          "match": "\\.\\.\\."
        },
        {
          "name": "keyword.operator.concat.lux",
          "match": "\\.\\."
        },
        {
          "name": "keyword.operator.arithmetic.lux",
          "match": "\\+|-|\\*|/|%|\\^|#"
        },
        {
          "name": "keyword.operator.optional.lux",
          "match": "\\?\\.|\\?"
        },
        {
          "name": "keyword.operator.nonnull.lux",
          "match": "(?<=[\\w)\\]])!(?![=\\w])"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "match": "(?<=[.:])([A-Za-z_]\\w*)",
          "captures": {
            "1": { "name": "variable.other.property.lux" }
          }
        },
        {
          "match": "\\b([A-Z][\\w]*)\\b",
          "captures": {
            "1": { "name": "entity.name.type.lux" }
          }
        }
      ]
    }
  }
}
