{
  "name": "lux-lang",
  "displayName": "Lux - A typed superset of Lua",
  "description": "Language support for Lua Lux — the typed Lua transpiler",
  "version": "0.1.0",
  "publisher": "DasDarki",
  "license": "MIT",
  "icon": "icon.png",
  "homepage": "https://github.com/LuaLux/lux#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/LuaLux/lux.git"
  },
  "bugs": {
    "url": "https://github.com/LuaLux/lux/issues"
  },
  "keywords": [
    "lux",
    "lua",
    "luajit",
    "transpiler",
    "type-checker"
  ],
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:lux"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "lux",
        "aliases": [
          "Lux",
          "lux"
        ],
        "extensions": [
          ".lux"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icon.png",
          "dark": "./icon.png"
        }
      },
      {
        "id": "lux",
        "aliases": [
          "Lux Declaration"
        ],
        "extensions": [
          ".d.lux"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icon.png",
          "dark": "./icon.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "lux",
        "scopeName": "source.lux",
        "path": "./syntaxes/lux.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "lux.compileFile",
        "title": "Lux: Compile this file",
        "category": "Lux"
      }
    ],
    "configuration": {
      "title": "Lux",
      "properties": {
        "lux.serverPath": {
          "type": "string",
          "default": "",
          "description": "Path to the Lux compiler executable. If empty, 'lux' must be on PATH."
        },
        "lux.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace communication between VS Code and the Lux language server."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0"
  }
}
