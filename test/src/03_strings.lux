import { section, expectEq, expect } from "_runner"

export function run(): nil
    section("strings")

    -- String form variants
    expectEq("dq", "hello", "hello")
    expectEq("sq", 'world', "world")
    expectEq("long bracket", [[multi
line]], "multi\nline")

    -- Common library calls
    expectEq("string.sub", string.sub("abcdef", 2, 4), "bcd")
    expectEq("string.upper", string.upper("abc"), "ABC")
    expectEq("string.lower", string.lower("XYZ"), "xyz")
    expectEq("string.rep", string.rep("ab", 3), "ababab")
    expectEq("string.byte", string.byte("A"), 65)
    expectEq("string.char", string.char(65, 66), "AB")
    expectEq("string.len", string.len("hello"), 5)
    expectEq("string.format int", string.format("%d", 42), "42")
    expectEq("string.format hex", string.format("%x", 255), "ff")

    -- # length operator
    expectEq("# on string", #"abcde", 5)

    -- Interpolated string `Hello {name}` (Lux feature, default-on)
    local name: string = "Lux"
    expectEq("interp basic", `Hello {name}`, "Hello Lux")

    local n: number = 7
    expectEq("interp with number", `n={n}`, "n=" .. tostring(n))
end
