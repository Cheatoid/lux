import { section, expectEq, expect } from "_runner"

export function run(): nil
    section("control flow")

    -- if / elseif / else
    local mut tag: string = ""
    local x: number = 7
    if x < 0 then
        tag = "neg"
    elseif x == 0 then
        tag = "zero"
    else
        tag = "pos"
    end
    expectEq("if/elseif/else", tag, "pos")

    -- while
    local mut i: number = 0
    local mut sum: number = 0
    while i < 5 do
        sum = sum + i
        i = i + 1
    end
    expectEq("while sum", sum, 10)

    -- repeat-until
    local mut k: number = 0
    repeat
        k = k + 1
    until k >= 3
    expectEq("repeat-until", k, 3)

    -- numeric for (default step)
    local mut total: number = 0
    for j = 1, 4 do
        total = total + j
    end
    expectEq("numeric for", total, 10)

    -- numeric for with step
    local mut acc: number = 0
    for j = 10, 1, -1 do
        acc = acc + 1
    end
    expectEq("numeric for step -1", acc, 10)

    -- generic for over ipairs
    local arr: number[] = { 2, 4, 6, 8 }
    local mut s: number = 0
    for _, v in ipairs(arr) do
        s = s + v
    end
    expectEq("generic for ipairs sum", s, 20)

    -- break
    local mut bsum: number = 0
    for j = 1, 10 do
        if j > 3 then break end
        bsum = bsum + j
    end
    expectEq("break", bsum, 6)

    -- break with depth (nested)
    local mut hits: number = 0
    for a = 1, 3 do
        for b = 1, 3 do
            if a == 2 and b == 2 then break 2 end
            hits = hits + 1
        end
    end
    expectEq("break 2", hits, 4)

    -- continue
    local mut csum: number = 0
    for j = 1, 5 do
        if j == 3 then continue end
        csum = csum + j
    end
    expectEq("continue", csum, 12)

    -- do block (own scope)
    local mut outer: number = 1
    do
        local outer: number = 99
        expectEq("do block shadows", outer, 99)
    end
    expectEq("do block leaves outer", outer, 1)

    -- goto / label (file-level loop body to keep label visible to goto)
    local mut hops: number = 0
    for j = 1, 5 do
        if j == 3 then goto skip end
        hops = hops + 1
        ::skip::
    end
    expectEq("goto/label", hops, 4)
end
