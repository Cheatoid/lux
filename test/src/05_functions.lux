import { section, expectEq, expect } from "_runner"

local function double(n: number): number
    return n * 2
end

local function greet(name: string, greeting: string = "Hello"): string
    return greeting .. ", " .. name
end

local function variadic(...: number): number
    local total: number = 0
    for _, v in ipairs({ ... }) do
        total = total + v
    end
    return total
end

local function divmod(a: number, b: number): (number, number)
    return a // b, a % b
end

local function makeCounter(): () -> number
    local mut n: number = 0
    return function(): number
        n = n + 1
        return n
    end
end

export function run(): nil
    section("functions")

    expectEq("simple call", double(21), 42)

    expectEq("default param used", greet("Lux"), "Hello, Lux")
    expectEq("default param overridden", greet("Lux", "Hi"), "Hi, Lux")

    expectEq("varargs sum 0", variadic(), 0)
    expectEq("varargs sum 4", variadic(1, 2, 3, 4), 10)

    -- Multi-return
    local q, r = divmod(17, 5)
    expectEq("multi-return q", q, 3)
    expectEq("multi-return r", r, 2)

    -- Closure
    local counter = makeCounter()
    expectEq("closure 1st call", counter(), 1)
    expectEq("closure 2nd call", counter(), 2)
    expectEq("closure 3rd call", counter(), 3)

    -- Pre/post increment + decrement (Lux-specific operators)
    local mut a: number = 5
    a++
    expectEq("post-inc", a, 6)
    a~~
    expectEq("post-dec", a, 5)
    ++a
    expectEq("pre-inc", a, 6)
    ~~a
    expectEq("pre-dec", a, 5)

    -- Function-as-value
    local fn = double
    expectEq("function as value", fn(7), 14)
end
