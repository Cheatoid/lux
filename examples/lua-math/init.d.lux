-- Type declarations for the lua-math runtime module (init.lua). The Lux
-- compiler matches this declaration by name when the consumer writes
-- `import { ... } from "lua-math"`, so the imports type-check while the
-- generated Lua code still resolves to the real init.lua at runtime.

declare module "lua-math"
    interface Vec2
        x: number
        y: number
    end

    --- Linear interpolation between `a` and `b` at parameter `t in [0, 1]`.
    ---@param a start value
    ---@param b end value
    ---@param t interpolation factor; clamped at the call site if needed
    function lerp(a: number, b: number, t: number): number

    --- Clamps `x` into the closed interval `[lo, hi]`.
    function clamp(x: number, lo: number, hi: number): number

    --- Variadic sum of every argument, all expected to be numbers.
    function sum(...: number): number

    --- Mean of `values`. Returns `0` when `values` is empty.
    function average(values: number[]): number

    --- Builds a Vec2 table with the given coordinates.
    function vec2(x: number, y: number): Vec2

    --- Magnitude of a Vec2 produced by `vec2`.
    function length2(v: Vec2): number
end
