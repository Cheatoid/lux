--- Case-conversion helpers. Reachable from a consumer as
--- `import { capitalize } from "lux-strings/case"`.

--- Returns `s` with the first ASCII letter upper-cased; non-letters pass
--- through untouched.
---@param s the input string
---@return string the capitalised copy
export function capitalize(s: string): string
    if #s == 0 then return s end
    local first: string = string.upper(string.sub(s, 1, 1))
    local rest: string = string.sub(s, 2)
    return first .. rest
end

--- Lower-cases every character in `s` via `string.lower`.
export function lower(s: string): string
    return string.lower(s)
end

--- Upper-cases every character in `s` via `string.upper`.
export function upper(s: string): string
    return string.upper(s)
end
