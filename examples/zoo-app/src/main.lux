--- zoo-app: smoke-test consumer that pulls in two libraries through the
--- package manager and exercises the import / module / type system.

import { trim, padLeft, startsWith } from "lux-strings"
import { capitalize } from "lux-strings/case"
import { lerp, clamp, sum, vec2, length2, Vec2 } from "lua-math"

--- Local imports: resolver picks up sibling files and folders in src/.
import { formatLabel, padCols } from "utils"
import { Animal, kinds } from "animals"
import { Cat } from "animals/cat"
import { Dog } from "animals/dog"

--- Builds the welcome banner for an animal name. Demonstrates that a string
--- value flows through several library calls while the type checker tracks
--- it as `string` end-to-end.
function welcome(rawName: string): string
    local name: string = capitalize(trim(rawName))
    local prefix: string = padLeft("> ", 4, " ")
    return prefix .. "Welcome, " .. name .. "!"
end

--- Mixes a Lux library (`startsWith`) with a Lua-side helper (`clamp`) to
--- prove cross-language calls work and arguments stay type-safe.
function classify(noise: string, decibels: number): string
    local volume: number = clamp(decibels, 0, 120)
    if startsWith(noise, "ROAR") then
        return "loud (" .. tostring(volume) .. " dB)"
    end
    return "quiet (" .. tostring(volume) .. " dB)"
end

print(welcome("  whiskers  "))
print(classify("ROAR!", 95))
print(classify("meow", 240))

--- Pull a vec2 from the Lua library so the type-checker has to round-trip a
--- structured value through the `Vec2` interface declared in init.d.lux.
local origin = vec2(3, 4)
print("|origin| = " .. tostring(length2(origin)))
print("lerp(0,10,0.25) = " .. tostring(lerp(0, 10, 0.25)))
print("sum(1..5) = " .. tostring(sum(1, 2, 3, 4, 5)))

--- Local animals: typed via the Animal interface from animals/init.lux,
--- instantiated from sibling files in the same folder via `new`.
local critters: Animal[] = { new Cat("Whiskers"), new Dog("Rex") }
print(formatLabel("kinds", table.concat(kinds(), ", ")))
for _, a in ipairs(critters) do
    print(formatLabel(padCols(a.name, 10), a:sound()))
end