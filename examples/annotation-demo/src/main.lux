--- annotation-demo: showcases compile-time IR rewriting via the @log
--- annotation defined in annotations/log.lux. Each annotated function gets
--- a `print("[log] ...")` prepended to its body at compile time, so the
--- generated Lua is identical to what a developer would have hand-written.

@log
function greet(name: string): string
    return "Hello, " .. name .. "!"
end

@log("computing sum")
function add(a: number, b: number): number
    return a + b
end

@log(message = "stringifying number")
function describe(n: number): string
    return "the number is " .. tostring(n)
end

print(greet("Lux"))
print("2 + 3 =", add(2, 3))
print(describe(42))